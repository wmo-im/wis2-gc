export WIS2_GC_STORAGE_URL=http://wis2-gc-storage:9000
export WIS2_GC_STORAGE_PATH=wis2-gc-bucket
export AWS_ACCESS_KEY_ID=minioadmin
export AWS_SECRET_ACCESS_KEY=minioadmin
export ENABLE_CRON=true
