export WIS2_GC_URL=http://localhost
export WIS2_GC_STORAGE_DATA_RETENTION_DAYS=2
export WIS2_GC_PYWIS_PUBSUB_CONFIG=/app/docker/pywis-pubsub.yml
export WIS2_GC_CACHE_URL=redis://wis2-gc-cache:6379
export WIS2_GC_CACHE_RETENTION_SECONDS=86400
export WIS2_GC_BROKER_URL=mqtt://wis2-gc:wis2-gc@wis2-gc-broker:1883
